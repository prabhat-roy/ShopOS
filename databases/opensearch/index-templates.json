{
  "templates": [
    {
      "name": "shopos-logs",
      "template": {
        "index_patterns": ["shopos-logs-*"],
        "template": {
          "settings": {
            "number_of_shards": 2,
            "number_of_replicas": 1,
            "index.lifecycle.name": "shopos-logs-policy",
            "index.lifecycle.rollover_alias": "shopos-logs",
            "index.codec": "best_compression"
          },
          "mappings": {
            "dynamic": "strict",
            "properties": {
              "@timestamp":  { "type": "date" },
              "level":       { "type": "keyword" },
              "service":     { "type": "keyword" },
              "tenant_id":   { "type": "keyword" },
              "trace_id":    { "type": "keyword" },
              "span_id":     { "type": "keyword" },
              "message":     { "type": "text", "fields": { "keyword": { "type": "keyword", "ignore_above": 512 } } },
              "error": {
                "type": "object",
                "properties": {
                  "type":       { "type": "keyword" },
                  "message":    { "type": "text" },
                  "stacktrace": { "type": "text", "index": false }
                }
              },
              "http": {
                "type": "object",
                "properties": {
                  "method":      { "type": "keyword" },
                  "path":        { "type": "keyword" },
                  "status_code": { "type": "short" },
                  "duration_ms": { "type": "integer" }
                }
              },
              "k8s": {
                "type": "object",
                "properties": {
                  "pod":       { "type": "keyword" },
                  "namespace": { "type": "keyword" },
                  "node":      { "type": "keyword" }
                }
              }
            }
          }
        },
        "priority": 100
      }
    },
    {
      "name": "shopos-audit",
      "template": {
        "index_patterns": ["shopos-audit-*"],
        "template": {
          "settings": {
            "number_of_shards": 1,
            "number_of_replicas": 1,
            "index.lifecycle.name": "shopos-audit-policy"
          },
          "mappings": {
            "dynamic": "strict",
            "properties": {
              "@timestamp":   { "type": "date" },
              "actor_id":     { "type": "keyword" },
              "actor_type":   { "type": "keyword" },
              "tenant_id":    { "type": "keyword" },
              "action":       { "type": "keyword" },
              "resource_type":{ "type": "keyword" },
              "resource_id":  { "type": "keyword" },
              "outcome":      { "type": "keyword" },
              "ip_address":   { "type": "ip" },
              "user_agent":   { "type": "text", "index": false },
              "changes": {
                "type": "object",
                "properties": {
                  "field":     { "type": "keyword" },
                  "old_value": { "type": "text", "index": false },
                  "new_value": { "type": "text", "index": false }
                }
              }
            }
          }
        },
        "priority": 100
      }
    },
    {
      "name": "shopos-security",
      "template": {
        "index_patterns": ["shopos-security-*"],
        "template": {
          "settings": {
            "number_of_shards": 1,
            "number_of_replicas": 1,
            "index.lifecycle.name": "shopos-security-policy"
          },
          "mappings": {
            "dynamic": "strict",
            "properties": {
              "@timestamp":   { "type": "date" },
              "event_type":   { "type": "keyword" },
              "tenant_id":    { "type": "keyword" },
              "user_id":      { "type": "keyword" },
              "ip_address":   { "type": "ip" },
              "severity":     { "type": "keyword" },
              "rule_id":      { "type": "keyword" },
              "description":  { "type": "text" },
              "raw_event":    { "type": "text", "index": false }
            }
          }
        },
        "priority": 100
      }
    }
  ],
  "ilm_policies": {
    "shopos-logs-policy": {
      "policy": {
        "phases": {
          "hot":    { "min_age": "0ms",  "actions": { "rollover": { "max_size": "50gb", "max_age": "1d" } } },
          "warm":   { "min_age": "3d",   "actions": { "shrink": { "number_of_shards": 1 }, "forcemerge": { "max_num_segments": 1 } } },
          "cold":   { "min_age": "14d",  "actions": { "allocate": { "require": { "data": "cold" } } } },
          "delete": { "min_age": "30d",  "actions": { "delete": {} } }
        }
      }
    },
    "shopos-audit-policy": {
      "policy": {
        "phases": {
          "hot":    { "min_age": "0ms", "actions": { "rollover": { "max_age": "7d" } } },
          "delete": { "min_age": "365d","actions": { "delete": {} } }
        }
      }
    },
    "shopos-security-policy": {
      "policy": {
        "phases": {
          "hot":    { "min_age": "0ms", "actions": { "rollover": { "max_age": "7d" } } },
          "delete": { "min_age": "90d", "actions": { "delete": {} } }
        }
      }
    }
  }
}

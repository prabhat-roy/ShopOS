model
  schema 1.1

type user

type organization
  relations
    define member: [user]
    define admin: [user]

type product
  relations
    define can_view: [user] or member from organization
    define can_edit: [user] or admin from organization
    define can_delete: admin from organization

type order
  relations
    define owner: [user]
    define can_view: owner or admin from organization
    define can_cancel: owner

type role
  relations
    define assignee: [user]

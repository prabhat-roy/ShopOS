# =============================================================================
# ShopOS — OpenLineage environment variables
#
# These variables are consumed by:
#   - Apache Airflow (via openlineage-airflow plugin)
#   - Apache Spark  (via openlineage-spark listener)
#   - dbt           (via openlineage-dbt integration)
#
# Copy to .env or inject via Kubernetes Secret / HashiCorp Vault.
# Reference: https://openlineage.io/docs/client/python/
# =============================================================================

# ── Marquez backend ───────────────────────────────────────────────────────────
# URL of the Marquez (or any OpenLineage-compatible) backend
OPENLINEAGE_URL=http://marquez:5000

# Namespace groups all ShopOS lineage events in the Marquez UI
OPENLINEAGE_NAMESPACE=shopos

# API key (leave empty if Marquez is deployed without authentication)
# When using an authenticated deployment, set this via Vault:
#   vault kv get secret/openlineage/api-key
OPENLINEAGE_API_KEY=

# ── Transport settings ────────────────────────────────────────────────────────
# Timeout in milliseconds for HTTP requests to the lineage backend
OPENLINEAGE_CLIENT_TIMEOUT=5000

# Maximum number of retries on transport failure
OPENLINEAGE_CLIENT_RETRY_COUNT=3

# Backoff multiplier between retries (seconds)
OPENLINEAGE_CLIENT_RETRY_BACKOFF=1.5

# ── Airflow-specific ──────────────────────────────────────────────────────────
# The Airflow OpenLineage plugin reads OPENLINEAGE_URL and OPENLINEAGE_NAMESPACE
# directly. These vars are read by openlineage-airflow automatically.
AIRFLOW__OPENLINEAGE__TRANSPORT={"type":"http","url":"http://marquez:5000","endpoint":"api/v1/lineage"}
AIRFLOW__OPENLINEAGE__NAMESPACE=shopos
AIRFLOW__OPENLINEAGE__DISABLED=false

# ── Spark-specific ────────────────────────────────────────────────────────────
# These map to spark-lineage.conf — set here for environments using env-var injection
SPARK_OPENLINEAGE_URL=http://marquez:5000/api/v1/lineage
SPARK_OPENLINEAGE_NAMESPACE=shopos
SPARK_OPENLINEAGE_APP_NAME=shopos-spark

# ── dbt-specific ─────────────────────────────────────────────────────────────
# Consumed by the dbt-openlineage integration or openlineage-dbt CLI wrapper
DBT_OPENLINEAGE_URL=http://marquez:5000
DBT_OPENLINEAGE_NAMESPACE=shopos

# ── Kafka transport alternative ───────────────────────────────────────────────
# Uncomment to emit lineage events to Kafka instead of HTTP
# OPENLINEAGE_TRANSPORT=kafka
# OPENLINEAGE_TRANSPORT_KAFKA_BOOTSTRAP_SERVERS=kafka:9092
# OPENLINEAGE_TRANSPORT_KAFKA_TOPIC=openlineage.events
# OPENLINEAGE_TRANSPORT_KAFKA_PROPERTIES_COMPRESSION_TYPE=snappy

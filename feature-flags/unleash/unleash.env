# Unleash environment variables
# Copy to .env and fill in real values before deploying

UNLEASH_DATABASE_URL=postgresql://unleash:changeme@postgres:5432/unleash
UNLEASH_SECRET_KEY=changeme-replace-with-at-least-32-char-secret
DATABASE_SSL=false
LOG_LEVEL=info
UNLEASH_URL=http://unleash.shopos.internal
INIT_FRONTEND_API_TOKENS=default:development.unleash-insecure-frontend-api-token
INIT_CLIENT_API_TOKENS=default:development.unleash-insecure-api-token

# HTTP server port
HTTP_PORT=8092

# Postgres connection string
DATABASE_URL=postgres://shopos:shopos@localhost:5432/dead_letter?sslmode=disable

# Maximum number of open database connections
DB_MAX_CONNS=10

# Comma-separated list of Kafka broker addresses
KAFKA_BROKERS=localhost:9092

# Kafka consumer group ID
KAFKA_GROUP_ID=dead-letter-service

# Comma-separated list of DLQ topics to consume
KAFKA_DLQ_TOPICS=commerce.order.placed.dlq,commerce.payment.processed.dlq,identity.user.registered.dlq

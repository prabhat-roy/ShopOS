HTTP_PORT=8091
ENV=development

DATABASE_URL=postgres://postgres:postgres@localhost:5432/webhooks?sslmode=disable
DB_MAX_CONNS=10
DB_TIMEOUT=5s

KAFKA_BROKERS=localhost:9092
KAFKA_GROUP_ID=webhook-service
KAFKA_WATCH_TOPICS=commerce.order.placed,commerce.order.cancelled,commerce.payment.processed

DELIVERY_TIMEOUT=10s
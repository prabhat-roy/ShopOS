# HTTP server port
HTTP_PORT=8094

# gRPC port (reserved for future gRPC implementation)
GRPC_PORT=50059

# PostgreSQL connection string
DATABASE_URL=postgres://postgres:password@localhost:5432/event_replay?sslmode=disable

# Maximum number of open database connections
DB_MAX_CONNS=10

# Base URL of the event-store-service
EVENT_STORE_URL=http://event-store-service:8095

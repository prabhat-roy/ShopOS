PORT=8090
ENV=development

# How often to probe targets
CHECK_INTERVAL=15s
CHECK_TIMEOUT=3s

# Consecutive failures before marking a target unhealthy
UNHEALTHY_THRESHOLD=3

# Comma-separated list of name=url pairs to probe
HEALTH_TARGETS=api-gateway=http://api-gateway:8080/healthz,order-service=http://order-service:8080/healthz,payment-service=http://payment-service:8080/healthz

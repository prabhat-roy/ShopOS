HTTP_PORT=8094
GRPC_PORT=50054
ENV=development

DATABASE_URL=postgres://postgres:postgres@localhost:5432/saga?sslmode=disable

KAFKA_BROKERS=localhost:9092
KAFKA_GROUP_ID=saga-orchestrator

# Consumed topics (inputs)
TOPIC_ORDER_PLACED=commerce.order.placed
TOPIC_PAYMENT_RESULT=commerce.payment.processed
TOPIC_INVENTORY_RESULT=supplychain.inventory.reserved
TOPIC_SHIPMENT_RESULT=supplychain.shipment.created

# Produced topics (commands)
TOPIC_RESERVE_INVENTORY=supplychain.inventory.reserve
TOPIC_PROCESS_PAYMENT=commerce.payment.process
TOPIC_CREATE_SHIPMENT=supplychain.shipment.create
TOPIC_ORDER_CANCELLED=commerce.order.cancelled

STEP_TIMEOUT=30s

# graphql-gateway runtime configuration
# Copy this file to .env and adjust values for your environment.
# Never commit real secrets.

# HTTP port the gateway listens on (default: 8086)
HTTP_PORT=8086

# Downstream service base URLs (no trailing slash)
CATALOG_URL=http://product-catalog-service:50070
CART_URL=http://cart-service:50080
ORDERS_URL=http://order-service:50082
USER_URL=http://user-service:50061

# Request timeout for downstream calls in milliseconds (default: 5000)
DOWNSTREAM_TIMEOUT_MS=5000

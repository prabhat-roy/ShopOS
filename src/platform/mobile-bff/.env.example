PORT=8082
ENV=development

GRPC_TIMEOUT_MS=10000

# CORS — comma-separated origins or *
CORS_ALLOWED_ORIGINS=*

# Upstream gRPC service addresses
AUTH_SERVICE_ADDR=auth-service:50060
USER_SERVICE_ADDR=user-service:50061
CATALOG_SERVICE_ADDR=product-catalog-service:50070
CART_SERVICE_ADDR=cart-service:50080
ORDER_SERVICE_ADDR=order-service:50082
NOTIFICATION_SERVICE_ADDR=push-notification-service:4000

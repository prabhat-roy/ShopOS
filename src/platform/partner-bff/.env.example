PORT=8083
ENV=development
GRPC_TIMEOUT=10s

# API keys for partner authentication — format: key:partnerID,key2:partnerB
PARTNER_API_KEYS=change-me-key1:partnerA,change-me-key2:partnerB

# Upstream gRPC service addresses
CATALOG_SERVICE_ADDR=product-catalog-service:50070
INVENTORY_SERVICE_ADDR=inventory-service:50074
ORDER_SERVICE_ADDR=order-service:50082
WEBHOOK_SERVICE_ADDR=webhook-service:8091
ORG_SERVICE_ADDR=organization-service:50160
CONTRACT_SERVICE_ADDR=contract-service:50161
QUOTE_SERVICE_ADDR=quote-rfq-service:50162

# consent-management-service environment variables
# Copy to .env and fill in values before running

# Application
NODE_ENV=development
HTTP_PORT=8408
GRPC_PORT=50127
LOG_LEVEL=info

# PostgreSQL
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/consent_db

# Database pool settings
DB_POOL_MAX=10
DB_POOL_MIN=2
DB_IDLE_TIMEOUT_MS=30000
DB_CONNECTION_TIMEOUT_MS=2000

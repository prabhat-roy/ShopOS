# recently-viewed-service environment variables
# Copy this file to .env and fill in the values.

HTTP_PORT=8404
GRPC_PORT=50124

# Redis connection URL
REDIS_URL=redis://localhost:6379/1

# Maximum number of recently viewed items to retain per customer
MAX_ITEMS=50

# TTL for each customer's recently-viewed list (Go duration string)
ITEM_TTL=168h

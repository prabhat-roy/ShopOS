# HTTP server port
HTTP_PORT=8196

# Kafka broker addresses (comma-separated)
KAFKA_BROKERS=localhost:9092

# Kafka consumer group ID
KAFKA_GROUP_ID=search-analytics-service

# Kafka topics to consume (comma-separated)
KAFKA_TOPICS=analytics.search.performed

# Cassandra contact points (comma-separated)
CASSANDRA_CONTACT_POINTS=localhost

# Cassandra keyspace
CASSANDRA_KEYSPACE=search_analytics

# Logging verbosity
LOG_LEVEL=info

HTTP_PORT=8700

KAFKA_BROKERS=localhost:9092
KAFKA_TOPICS=analytics.page.viewed,analytics.product.clicked,analytics.search.performed
KAFKA_GROUP_ID=analytics-service

CASSANDRA_HOSTS=127.0.0.1
CASSANDRA_KEYSPACE=analytics

# Set to "memory" for local dev/testing without Cassandra
STORE_BACKEND=cassandra

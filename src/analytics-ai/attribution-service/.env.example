# HTTP server port
HTTP_PORT=8194

# Kafka broker addresses (comma-separated)
KAFKA_BROKERS=localhost:9092

# Kafka consumer group ID
KAFKA_GROUP_ID=attribution-service

# Kafka topics to consume (comma-separated)
KAFKA_TOPICS=analytics.page.viewed,analytics.product.clicked,commerce.order.placed

# Cassandra contact points (comma-separated)
CASSANDRA_CONTACT_POINTS=localhost

# Cassandra keyspace
CASSANDRA_KEYSPACE=attribution

# Logging verbosity
LOG_LEVEL=info

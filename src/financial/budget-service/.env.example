# budget-service environment variables
# Copy this file to .env and fill in the values for local development.
# NEVER commit .env to version control.

# ---- Server ----------------------------------------------------------------
HTTP_PORT=8308
GRPC_PORT=50117
LOG_LEVEL=info

# ---- Database (PostgreSQL) -------------------------------------------------
# Either set DATABASE_URL directly ...
DATABASE_URL=postgres://postgres:secret@localhost:5432/budget_service?sslmode=disable

# ... or set individual components (DATABASE_URL takes precedence when set).
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=secret
DB_NAME=budget_service
DB_SSLMODE=disable

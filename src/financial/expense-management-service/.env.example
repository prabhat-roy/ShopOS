# expense-management-service — environment variable reference
# Copy this file to .env and fill in real values before running locally.

# HTTP server bind address
HTTP_PORT=8305

# gRPC server bind address
GRPC_ADDR=:50114

# PostgreSQL connection settings
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=changeme
DB_NAME=expense_management
DB_SSLMODE=disable

# Convenience DSN (used by golang-migrate CLI via make migrate-up)
DATABASE_URL=postgres://postgres:changeme@localhost:5432/expense_management?sslmode=disable

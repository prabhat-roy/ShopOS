# ── accounting-service environment variables ──────────────────────────────────
# Copy this file to .env and fill in real values before running locally.
# Never commit .env to source control.

# HTTP port
SERVER_PORT=8301

# PostgreSQL
DB_URL=jdbc:postgresql://localhost:5432/accounting_db
DB_USERNAME=accounting_user
DB_PASSWORD=changeme

# JPA / Flyway (override if needed)
# SPRING_JPA_SHOW_SQL=false
# SPRING_FLYWAY_ENABLED=true

# Logging
LOGGING_LEVEL_COM_SHOPOS=INFO

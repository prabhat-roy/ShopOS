# ── reconciliation-service environment variables ─────────────────────────────
# Copy this file to .env and fill in real values before running locally.
# Never commit .env to source control.

# HTTP port
SERVER_PORT=8303

# PostgreSQL
DB_URL=jdbc:postgresql://localhost:5432/reconciliation_db
DB_USERNAME=recon_user
DB_PASSWORD=changeme

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_CONSUMER_GROUP=reconciliation-service-group

# JPA / Flyway (override if needed)
# SPRING_JPA_SHOW_SQL=false
# SPRING_FLYWAY_ENABLED=true

# Logging
LOGGING_LEVEL_COM_SHOPOS=INFO
LOGGING_LEVEL_ORG_SPRINGFRAMEWORK_KAFKA=INFO

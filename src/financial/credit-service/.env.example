# credit-service environment variables
# Copy this file to .env and fill in the values for local development.
# NEVER commit .env to version control.

# ---- Server ----------------------------------------------------------------
HTTP_PORT=8306
GRPC_PORT=50115
LOG_LEVEL=info

# ---- Database (PostgreSQL) -------------------------------------------------
# Either set DATABASE_URL directly ...
DATABASE_URL=postgres://postgres:secret@localhost:5432/credit_service?sslmode=disable

# ... or set individual components (DATABASE_URL takes precedence when set).
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=secret
DB_NAME=credit_service
DB_SSLMODE=disable

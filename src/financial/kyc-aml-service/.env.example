# ============================================================
# kyc-aml-service environment variables
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.
# ============================================================

# PostgreSQL connection
DB_URL=jdbc:postgresql://localhost:5432/kycamldb
DB_USERNAME=kycaml
DB_PASSWORD=changeme

# Server port (matches application.properties default)
SERVER_PORT=8307

# Spring profile (local | staging | production)
SPRING_PROFILES_ACTIVE=local

# Logging level override (DEBUG | INFO | WARN | ERROR)
LOG_LEVEL_APP=INFO

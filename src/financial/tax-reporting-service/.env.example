# tax-reporting-service — environment variable reference
# Copy this file to .env and fill in real values before running locally.

# HTTP server bind address
HTTP_PORT=8304

# gRPC server bind address
GRPC_ADDR=:50113

# PostgreSQL connection settings
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=changeme
DB_NAME=tax_reporting
DB_SSLMODE=disable

# Convenience DSN (used by golang-migrate CLI via make migrate-up)
DATABASE_URL=postgres://postgres:changeme@localhost:5432/tax_reporting?sslmode=disable

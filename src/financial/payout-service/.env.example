# payout-service environment variables
# Copy this file to .env and fill in real values before running locally.
# NEVER commit .env to version control.

# ---- PostgreSQL connection ----
DB_URL=jdbc:postgresql://localhost:5432/payout_db
DB_USER=payout_user
DB_PASSWORD=changeme

# ---- Spring Boot ----
SERVER_PORT=8302
SPRING_PROFILES_ACTIVE=local

# ---- Logging ----
LOG_LEVEL_ROOT=INFO
LOG_LEVEL_APP=DEBUG

# checkout-service runtime configuration
# Copy to .env and adjust for your local environment.

# HTTP server port
HTTP_PORT=8132

# gRPC port (reserved for future gRPC interface)
GRPC_PORT=50081

# Downstream service base URLs (no trailing slash)
CART_URL=http://cart-service:50080
TAX_URL=http://tax-service:8133
ORDER_URL=http://order-service:50082

# Timeout for outbound HTTP calls (Go duration format)
HTTP_TIMEOUT=10s

# ============================================================
# affiliate-service — Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit .env to source control.
# ============================================================

# ---- Service ports ----
GRPC_PORT=50200

# ---- PostgreSQL connection string ----
# Format: postgres://user:password@host:port/dbname?sslmode=disable
DATABASE_URL=postgres://postgres:postgres@localhost:5432/affiliate_db?sslmode=disable

# ---- Affiliate settings ----
TRACKING_LINK_BASE_URL=https://shop.example.com/a
COOKIE_TTL_DAYS=30
DEFAULT_COMMISSION_PERCENT=5.0

# ---- Kafka ----
KAFKA_BROKERS=localhost:9092

# ---- Logging ----
LOG_LEVEL=info

# ============================================================
# commission-payout-service — Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit .env to source control.
# ============================================================

# ---- Service ports ----
GRPC_PORT=50203

# ---- PostgreSQL connection string ----
# Format: postgres://user:password@host:port/dbname?sslmode=disable
DATABASE_URL=postgres://postgres:postgres@localhost:5432/commission_payout_db?sslmode=disable

# ---- Payout period ----
PAYOUT_PERIOD=monthly
PAYOUT_DAY_OF_MONTH=1
MINIMUM_PAYOUT_AMOUNT=10.00
CURRENCY=USD

# ---- Tax withholding ----
TAX_WITHHOLDING_PERCENT=0.0
TAX_THRESHOLD_ANNUAL=600.00

# ---- Kafka ----
KAFKA_BROKERS=localhost:9092

# ---- Logging ----
LOG_LEVEL=info

# ============================================================
# influencer-service — Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit .env to source control.
# ============================================================

# ---- Service ports ----
GRPC_PORT=50202

# ---- PostgreSQL connection string ----
# Format: postgres://user:password@host:port/dbname?sslmode=disable
DATABASE_URL=postgres://postgres:postgres@localhost:5432/influencer_db?sslmode=disable

# ---- Campaign settings ----
UTM_DEFAULT_SOURCE=influencer
UTM_DEFAULT_MEDIUM=social
ATTRIBUTION_WINDOW_DAYS=7

# ---- Kafka ----
KAFKA_BROKERS=localhost:9092

# ---- Logging ----
LOG_LEVEL=info

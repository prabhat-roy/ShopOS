# ============================================================
# referral-service — Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit .env to source control.
# ============================================================

# ---- Service ports ----
GRPC_PORT=50201

# ---- PostgreSQL connection string ----
# Format: postgres://user:password@host:port/dbname?sslmode=disable
DATABASE_URL=postgres://postgres:postgres@localhost:5432/referral_db?sslmode=disable

# ---- Referral programme settings ----
REFERRAL_CODE_LENGTH=8
REFERRAL_LINK_BASE_URL=https://shop.example.com/ref
REFERRAL_EXPIRY_DAYS=90
REFERRER_REWARD_CREDIT=10.00
REFEREE_DISCOUNT_PERCENT=15.0

# ---- Kafka ----
KAFKA_BROKERS=localhost:9092

# ---- Logging ----
LOG_LEVEL=info

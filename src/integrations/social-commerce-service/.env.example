# ============================================================
# social-commerce-service — Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit .env to source control.
# ============================================================

# ---- Service ports ----
HTTP_PORT=8902
GRPC_PORT=50171

# ---- Node environment ----
NODE_ENV=production

# ---- Instagram Shopping / Graph API ----
# https://developers.facebook.com/docs/commerce-platform
INSTAGRAM_API_KEY=changeme
INSTAGRAM_CATALOG_ID=changeme
INSTAGRAM_BUSINESS_ACCOUNT_ID=changeme

# ---- TikTok Shop API ----
# https://partner.tiktokshop.com/doc
TIKTOK_API_KEY=changeme
TIKTOK_SHOP_ID=changeme
TIKTOK_APP_SECRET=changeme

# ---- Pinterest Catalog API ----
# https://developers.pinterest.com/docs/api/v5
PINTEREST_API_KEY=changeme
PINTEREST_AD_ACCOUNT_ID=changeme

# ---- Facebook Commerce / Catalog ----
# https://developers.facebook.com/docs/marketing-api/catalog
FACEBOOK_ACCESS_TOKEN=changeme
FACEBOOK_CATALOG_ID=changeme

# ---- In-memory sync history cap ----
MAX_SYNC_HISTORY=500
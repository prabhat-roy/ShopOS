# ============================================================
# pim-integration-service — Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit .env to source control.
# ============================================================

# ---- Service ports ----
GRPC_PORT=50195

# ---- PIM connection ----
PIM_API_URL=https://pim.internal.example.com/api
PIM_API_KEY=changeme

# ---- Sync settings ----
SYNC_INTERVAL_SECONDS=300
SYNC_BATCH_SIZE=500

# ---- Kafka ----
KAFKA_BROKERS=localhost:9092

# ---- Logging ----
LOG_LEVEL=info

# ============================================================
# erp-integration-service — Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit .env to source control.
# ============================================================

# ---- Service ports ----
SERVER_PORT=8900
GRPC_PORT=50170

# ---- SAP Connection (RFC/BAPI) ----
SAP_HOST=sap.internal.example.com
SAP_SYSTEM_NUMBER=00
SAP_CLIENT=100
SAP_USERNAME=SHOPOSSVC
SAP_PASSWORD=changeme

# ---- Oracle EBS / Fusion Connection ----
ORACLE_BASE_URL=https://oracle-erp.internal.example.com/ords
ORACLE_USERNAME=shopossvc
ORACLE_PASSWORD=changeme
ORACLE_RESPONSIBILITY_NAME=ORDER_MANAGEMENT

# ---- NetSuite Connection (OAuth 1.0a TBA) ----
NETSUITE_ACCOUNT_ID=1234567
NETSUITE_CONSUMER_KEY=changeme
NETSUITE_CONSUMER_SECRET=changeme
NETSUITE_TOKEN_ID=changeme
NETSUITE_TOKEN_SECRET=changeme

# ---- Microsoft Dynamics 365 ----
DYNAMICS_BASE_URL=https://org.crm.dynamics.com/api/data/v9.2
DYNAMICS_TENANT_ID=00000000-0000-0000-0000-000000000000
DYNAMICS_CLIENT_ID=00000000-0000-0000-0000-000000000000
DYNAMICS_CLIENT_SECRET=changeme

# ---- Spring ----
SPRING_PROFILES_ACTIVE=production
LOGGING_LEVEL_COM_SHOPOS=INFO

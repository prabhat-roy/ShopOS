# ============================================================
# accounting-integration-service — Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit .env to source control.
# ============================================================

# ---- Service ports ----
SERVER_PORT=50196
GRPC_PORT=50196

# ---- QuickBooks Online (OAuth 2.0) ----
QBO_CLIENT_ID=changeme
QBO_CLIENT_SECRET=changeme
QBO_REFRESH_TOKEN=changeme
QBO_REALM_ID=changeme
QBO_ENVIRONMENT=sandbox

# ---- Xero (OAuth 2.0) ----
XERO_CLIENT_ID=changeme
XERO_CLIENT_SECRET=changeme
XERO_TENANT_ID=changeme

# ---- Sage Intacct ----
SAGE_COMPANY_ID=changeme
SAGE_USER_ID=changeme
SAGE_USER_PASSWORD=changeme
SAGE_CLIENT_ID=changeme
SAGE_CLIENT_SECRET=changeme

# ---- Kafka ----
KAFKA_BROKERS=localhost:9092
KAFKA_CONSUMER_GROUP=accounting-integration-service

# ---- Spring ----
SPRING_PROFILES_ACTIVE=production
LOGGING_LEVEL_COM_SHOPOS=INFO

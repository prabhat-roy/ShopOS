# ============================================================
# cdp-integration-service — Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit .env to source control.
# ============================================================

# ---- CDP webhook ----
CDP_WEBHOOK_URL=https://api.segment.io/v1/track
CDP_WRITE_KEY=changeme

# ---- Kafka ----
KAFKA_BROKERS=localhost:9092
KAFKA_CONSUMER_GROUP=cdp-integration-service
KAFKA_TOPICS=analytics.page.viewed,analytics.product.clicked,analytics.search.performed,commerce.order.placed

# ---- HTTP ----
HTTP_PORT=8080

# ---- Retry settings ----
WEBHOOK_RETRY_MAX=3
WEBHOOK_RETRY_BACKOFF_MS=500

# ---- Logging ----
LOG_LEVEL=info

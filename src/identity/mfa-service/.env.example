# mfa-service — copy to .env and fill in values before running locally.

# HTTP listen port
HTTP_PORT=8102

# gRPC listen port (reserved for future gRPC transport)
GRPC_PORT=50064

# PostgreSQL connection string
DATABASE_URL=postgres://mfa_user:mfa_pass@localhost:5432/mfa_db?sslmode=disable

# Human-readable issuer shown in authenticator apps
SERVICE_NAME=mfa-service

# gdpr-service environment variables
# Copy to .env and fill in real values before running locally.

# HTTP server port (default: 8103)
HTTP_PORT=8103

# gRPC port – reserved for future gRPC transport (default: 50065)
GRPC_PORT=50065

# PostgreSQL connection string (required)
# Format: postgres://user:password@host:5432/dbname?sslmode=disable
DATABASE_URL=postgres://gdpr:gdpr_secret@localhost:5432/gdpr_db?sslmode=disable
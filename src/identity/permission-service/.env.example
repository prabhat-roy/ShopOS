# HTTP server port
HTTP_PORT=8101

# gRPC server port (placeholder; full gRPC added in Phase 2)
GRPC_PORT=50063

# Postgres connection string
# Format: postgres://user:password@host:5432/dbname?sslmode=disable
DATABASE_URL=postgres://permission:secret@localhost:5432/permission_db?sslmode=disable

# Maximum number of open database connections
DB_MAX_CONNS=10

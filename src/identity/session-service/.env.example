# HTTP server port
HTTP_PORT=8100

# gRPC port (reserved for future gRPC transport layer)
GRPC_PORT=50062

# Redis connection
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

# How long a session lives without activity before it expires.
# Accepts Go duration strings: 24h, 1h30m, etc.
SESSION_TTL=24h

# Device Fingerprint Service — example environment variables
# Copy this file to .env and populate the values for local development.

# HTTP server port
HTTP_PORT=8105

# gRPC port (reserved for future gRPC transport; not yet active)
GRPC_PORT=50067

# Redis connection
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=2

# Fingerprint record TTL in days
FP_TTL_DAYS=90

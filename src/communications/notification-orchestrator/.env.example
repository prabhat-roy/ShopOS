# HTTP server port
HTTP_PORT=8500

# Kafka broker addresses (comma-separated)
KAFKA_BROKERS=localhost:9092

# Kafka consumer group ID
KAFKA_GROUP_ID=notification-orchestrator

# Kafka client ID (used in producer + consumer)
KAFKA_CLIENT_ID=notification-orchestrator

# Input topics (comma-separated)
INPUT_TOPICS=notification.email.requested,notification.sms.requested,notification.push.requested

# Output topics (routed to downstream services)
EMAIL_TOPIC=email.send
SMS_TOPIC=sms.send
PUSH_TOPIC=push.send

# Kafka retry configuration
KAFKA_RETRY_ATTEMPTS=8
KAFKA_RETRY_INITIAL_TIME=300

# HTTP server port
HTTP_PORT=8502

# Kafka broker addresses (comma-separated)
KAFKA_BROKERS=localhost:9092

# Kafka consumer group ID
KAFKA_GROUP_ID=sms-service

# Kafka client ID
KAFKA_CLIENT_ID=sms-service

# Topic to consume SMS send events from
KAFKA_TOPIC=sms.send

# Kafka retry configuration
KAFKA_RETRY_ATTEMPTS=8
KAFKA_RETRY_INITIAL_TIME=300

# Simulated SMS delivery success rate (0.0 to 1.0)
SMS_SUCCESS_RATE=0.9

# Max number of SMS records to keep in memory
SMS_MAX_LOG_SIZE=10000

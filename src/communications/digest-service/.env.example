# HTTP server port
HTTP_PORT=8506

# PostgreSQL connection URL
DATABASE_URL=postgres://postgres:postgres@localhost:5432/digest?sslmode=disable

# Kafka broker addresses (comma-separated)
KAFKA_BROKERS=localhost:9092

# Kafka topic for outbound email send messages
KAFKA_TOPIC=email.send

# How often the scheduler checks for due digests (Go duration string)
DIGEST_CHECK_INTERVAL=1h

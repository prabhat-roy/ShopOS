# ============================================================
# supplier-rating-service — Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit .env to source control.
# ============================================================

# ---- Service ports ----
GRPC_PORT=50194

# ---- PostgreSQL connection string ----
# Format: postgres://user:password@host:port/dbname?sslmode=disable
DATABASE_URL=postgres://postgres:postgres@localhost:5432/supplier_rating_db?sslmode=disable

# ---- Scoring weights (must sum to 1.0) ----
WEIGHT_ON_TIME_DELIVERY=0.35
WEIGHT_DEFECT_RATE=0.30
WEIGHT_FILL_RATE=0.20
WEIGHT_LEAD_TIME_ACCURACY=0.15

# ---- Logging ----
LOG_LEVEL=info

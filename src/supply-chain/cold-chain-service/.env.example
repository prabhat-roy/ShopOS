# ============================================================
# cold-chain-service — Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit .env to source control.
# ============================================================

# ---- Service ports ----
GRPC_PORT=50193

# ---- MongoDB connection ----
# Format: mongodb://user:password@host:port/dbname
MONGODB_URI=mongodb://localhost:27017/cold_chain_db

# ---- Kafka ----
KAFKA_BROKERS=localhost:9092

# ---- Alert thresholds ----
TEMP_MAX_CELSIUS=8.0
TEMP_MIN_CELSIUS=-25.0
HUMIDITY_MAX_PERCENT=85

# ---- Logging ----
LOG_LEVEL=info

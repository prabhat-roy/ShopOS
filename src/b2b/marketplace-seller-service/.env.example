# marketplace-seller-service environment configuration
# Copy this file to .env and fill in values before running locally.

# HTTP server port
SERVER_PORT=8806

# Spring active profile (local | dev | staging | prod)
SPRING_PROFILES_ACTIVE=local

# PostgreSQL connection
DB_URL=jdbc:postgresql://localhost:5432/marketplace_seller
DB_USERNAME=shopos
DB_PASSWORD=shopos

# Logging
LOG_LEVEL_APP=INFO

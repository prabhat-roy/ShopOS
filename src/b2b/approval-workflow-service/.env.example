# HTTP and gRPC listen addresses
HTTP_PORT=8803
GRPC_ADDR=:50163

# PostgreSQL connection — use DATABASE_URL OR individual DB_* vars
DATABASE_URL=postgres://postgres:postgres@localhost:5432/approval_workflow?sslmode=disable

# Individual DB variables (used when DATABASE_URL is not set)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=approval_workflow
DB_SSLMODE=disable

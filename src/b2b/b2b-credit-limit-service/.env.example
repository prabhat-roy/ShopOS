# HTTP and gRPC listen addresses
HTTP_PORT=8804
GRPC_ADDR=:50164

# PostgreSQL connection — use DATABASE_URL OR individual DB_* vars
DATABASE_URL=postgres://postgres:postgres@localhost:5432/b2b_credit?sslmode=disable

# Individual DB variables (used when DATABASE_URL is not set)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=b2b_credit
DB_SSLMODE=disable

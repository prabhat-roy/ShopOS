project_id     = "your-gcp-project-id"
region         = "us-central1"
zone           = "us-central1-a"
name           = "jenkins"
environment    = "dev"
subnet_cidr    = "10.0.1.0/24"
vm_size        = "n2-standard-4"
disk_size_gb   = 200
admin_username = "ubuntu"
ui_source_cidr = "0.0.0.0/0"   # restrict to your IP for prod, e.g. "203.0.113.7/32"

# SSH keys: leave ssh_pub_key_path unset to auto-detect ~/.ssh/id_ed25519.pub or id_rsa.pub.
# After apply, connect from any shell:
#   ssh ubuntu@<jenkins_public_ip>
# ssh_pub_key_path = "/path/to/your-key.pub"

region             = "us-east-1"
environment        = "dev"
name               = "jenkins"
vpc_cidr           = "10.0.0.0/16"
public_subnet_cidr = "10.0.1.0/24"
instance_type      = "t3.xlarge"
volume_size        = 200
key_name           = "us-east-1"
allowed_cidr       = "0.0.0.0/0"  # Replace with your IP: "x.x.x.x/32"
private_key_path   = "/path/to/your-key.pem"

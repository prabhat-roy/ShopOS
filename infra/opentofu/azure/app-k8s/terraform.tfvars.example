subscription_id    = "your-azure-subscription-id"
location           = "East US"
cluster_name       = "shopos-aks-dev"
environment        = "dev"
kubernetes_version = null              # null = AKS default; or pin e.g. "1.30.5"
node_count         = 1
vm_size            = "Standard_D4s_v3"

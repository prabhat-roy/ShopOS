    {"name": "Auth Service", "type": "grpc-keyword", "url": "auth-service:50060", "interval": 60},
    {"name": "Order Service", "type": "grpc-keyword", "url": "order-service:50082", "interval": 60},
    {"name": "Payment Service", "type": "grpc-keyword", "url": "payment-service:50083", "interval": 30},
    {"name": "PostgreSQL", "type": "port", "hostname": "postgres", "port": 5432, "interval": 60},
    {"name": "Kafka", "type": "port", "hostname": "kafka", "port": 9092, "interval": 60},
    {"name": "Redis", "type": "redis", "url": "redis://redis:6379", "interval": 30},
    {"name": "Elasticsearch", "type": "http", "url": "http://elasticsearch:9200/_cluster/health", "interval": 60},
    {"name": "RabbitMQ", "type": "http", "url": "http://rabbitmq:15672/api/healthchecks/node", "interval": 60},

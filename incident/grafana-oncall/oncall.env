# Grafana OnCall environment variables
# Copy to .env and fill in real values before deploying

SECRET_KEY=changeme-replace-with-at-least-50-char-secret
BASE_URL=http://oncall.shopos.internal
DJANGO_SETTINGS_MODULE=settings.hobby
DATABASE_HOST=postgres
DATABASE_PORT=5432
DATABASE_NAME=oncall
DATABASE_USER=oncall
DATABASE_PASSWORD=changeme
BROKER_TYPE=redis
REDIS_URI=redis://redis:6379/0
GRAFANA_API_URL=http://grafana:3000

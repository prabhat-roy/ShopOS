# Cachet environment variables
# Copy to .env and fill in real values before deploying

APP_ENV=production
APP_DEBUG=false
APP_URL=http://status.shopos.internal
APP_KEY=base64:changeme-replace-with-real-laravel-key

DB_DRIVER=pgsql
DB_HOST=postgres
DB_DATABASE=cachet
DB_USERNAME=cachet
DB_PASSWORD=changeme

CACHE_DRIVER=database
SESSION_DRIVER=database
QUEUE_DRIVER=database

MAIL_DRIVER=smtp
MAIL_HOST=smtp.shopos.internal
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ADDRESS=noreply@shopos.internal
MAIL_NAME="ShopOS Status"

# ============================================================
# ShopOS — Root Environment Variable Reference
# ============================================================
# Copy to .env and fill in values for local development.
# Production secrets are managed via HashiCorp Vault + External Secrets Operator.
# NEVER commit .env to git.
# ============================================================

# ------------------------------------------------------------
# Platform
# ------------------------------------------------------------
ENVIRONMENT=development
LOG_LEVEL=info
PLATFORM_VERSION=1.0.0

# ------------------------------------------------------------
# PostgreSQL (shared local instance for development)
# Per-service databases are created automatically on startup.
# ------------------------------------------------------------
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=shopos
POSTGRES_PASSWORD=shopos_dev_password
POSTGRES_DB=shopos

# ------------------------------------------------------------
# MongoDB
# ------------------------------------------------------------
MONGO_URI=mongodb://shopos:shopos_dev_password@localhost:27017
MONGO_DB=shopos

# ------------------------------------------------------------
# Redis
# ------------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ------------------------------------------------------------
# Apache Kafka
# ------------------------------------------------------------
KAFKA_BROKERS=localhost:9092
KAFKA_SCHEMA_REGISTRY_URL=http://localhost:8081
KAFKA_GROUP_ID=shopos-local

# ------------------------------------------------------------
# RabbitMQ
# ------------------------------------------------------------
RABBITMQ_URL=amqp://shopos:shopos_dev_password@localhost:5672/
RABBITMQ_MANAGEMENT_URL=http://localhost:15672

# ------------------------------------------------------------
# NATS JetStream
# ------------------------------------------------------------
NATS_URL=nats://localhost:4222

# ------------------------------------------------------------
# Elasticsearch
# ------------------------------------------------------------
ELASTICSEARCH_URL=http://localhost:9200
ELASTICSEARCH_INDEX_PREFIX=shopos

# ------------------------------------------------------------
# Cassandra / ScyllaDB
# ------------------------------------------------------------
CASSANDRA_HOSTS=localhost
CASSANDRA_PORT=9042
CASSANDRA_KEYSPACE=shopos
CASSANDRA_USER=cassandra
CASSANDRA_PASSWORD=cassandra

# ------------------------------------------------------------
# ClickHouse
# ------------------------------------------------------------
CLICKHOUSE_HOST=localhost
CLICKHOUSE_PORT=9000
CLICKHOUSE_DB=shopos
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=

# ------------------------------------------------------------
# Weaviate (Vector DB)
# ------------------------------------------------------------
WEAVIATE_URL=http://localhost:8090
WEAVIATE_API_KEY=

# ------------------------------------------------------------
# Neo4j (Graph DB)
# ------------------------------------------------------------
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=shopos_dev_password

# ------------------------------------------------------------
# MinIO (Object Storage)
# ------------------------------------------------------------
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_MEDIA=media-assets
MINIO_BUCKET_DOCS=documents
MINIO_BUCKET_EXPORTS=data-exports
MINIO_USE_SSL=false

# ------------------------------------------------------------
# OpenSearch
# ------------------------------------------------------------
OPENSEARCH_URL=http://localhost:9201
OPENSEARCH_USER=admin
OPENSEARCH_PASSWORD=admin

# ------------------------------------------------------------
# etcd (Config Service)
# ------------------------------------------------------------
ETCD_ENDPOINTS=localhost:2379

# ------------------------------------------------------------
# Temporal (Workflow Engine)
# ------------------------------------------------------------
TEMPORAL_HOST=localhost:7233
TEMPORAL_NAMESPACE=shopos-local

# ------------------------------------------------------------
# Consul (Service Discovery)
# ------------------------------------------------------------
CONSUL_HTTP_ADDR=localhost:8500

# ------------------------------------------------------------
# Traefik
# ------------------------------------------------------------
TRAEFIK_API_PORT=8080
TRAEFIK_DASHBOARD_AUTH=admin:changeme

# ------------------------------------------------------------
# Identity / Auth
# ------------------------------------------------------------
JWT_SECRET=change-me-in-production-use-vault
JWT_EXPIRY_SECONDS=3600
REFRESH_TOKEN_EXPIRY_SECONDS=86400

KEYCLOAK_URL=http://localhost:8089
KEYCLOAK_REALM=shopos
KEYCLOAK_CLIENT_ID=shopos-api
KEYCLOAK_CLIENT_SECRET=change-me

# ------------------------------------------------------------
# External Payment Gateways (sandbox keys)
# ------------------------------------------------------------
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
PAYPAL_CLIENT_ID=...
PAYPAL_CLIENT_SECRET=...

# ------------------------------------------------------------
# Email (local dev uses MailHog)
# ------------------------------------------------------------
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@shopos.local

# ------------------------------------------------------------
# SMS (Twilio sandbox)
# ------------------------------------------------------------
TWILIO_ACCOUNT_SID=ACxxxxx
TWILIO_AUTH_TOKEN=...
TWILIO_FROM_NUMBER=+15005550006

# ------------------------------------------------------------
# Push Notifications
# ------------------------------------------------------------
FCM_SERVER_KEY=...
APNS_KEY_ID=...
APNS_TEAM_ID=...
APNS_P8_KEY_PATH=./certs/apns.p8

# ------------------------------------------------------------
# MLflow
# ------------------------------------------------------------
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_S3_ENDPOINT_URL=http://localhost:9000
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin

# ------------------------------------------------------------
# Observability (Phase 4)
# ------------------------------------------------------------
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=shopos-local
PROMETHEUS_PORT=9090
JAEGER_AGENT_HOST=localhost
JAEGER_AGENT_PORT=6831

# ------------------------------------------------------------
# Kubernetes (local dev — kind / minikube)
# ------------------------------------------------------------
KUBECONFIG=~/.kube/config
K8S_NAMESPACE=default
REGISTRY_URL=localhost:5000

# ------------------------------------------------------------
# CI / GitOps
# ------------------------------------------------------------
ARGOCD_SERVER=localhost:8088
ARGOCD_AUTH_TOKEN=...
GITEA_URL=http://localhost:3000
GITEA_TOKEN=...
HARBOR_URL=http://localhost:8082
HARBOR_USER=admin
HARBOR_PASSWORD=Harbor12345

{
  "_comment": "NATS JetStream stream definitions for ShopOS. Applied via nats stream add --config or the NATS CLI/SDK at service startup.",
  "streams": [
    {
      "name": "REALTIME_EVENTS",
      "description": "In-memory stream for high-frequency real-time events: page views, clicks, product interactions, price ticks. Consumed by event-tracking-service and personalization-service.",
      "subjects": ["realtime.>"],
      "retention": "limits",
      "storage": "memory",
      "max_age": 3600,
      "max_msgs": 1000000,
      "max_bytes": 536870912,
      "max_msg_size": 65536,
      "num_replicas": 1,
      "discard": "old",
      "duplicate_window": 120,
      "allow_rollup_hdrs": false,
      "deny_delete": false,
      "deny_purge": false,
      "consumers": [
        {
          "name": "event-tracking-consumer",
          "filter_subject": "realtime.>",
          "deliver_policy": "new",
          "ack_policy": "none",
          "replay_policy": "instant",
          "description": "event-tracking-service (Python) — fire-and-forget analytics ingestion"
        },
        {
          "name": "personalization-consumer",
          "filter_subject": "realtime.product.>",
          "deliver_policy": "new",
          "ack_policy": "explicit",
          "replay_policy": "instant",
          "max_ack_pending": 5000,
          "description": "personalization-service (Python) — real-time user behaviour signals"
        }
      ]
    },
    {
      "name": "NOTIFICATIONS",
      "description": "Durable file-backed work-queue stream for notification delivery. Ensures at-least-once delivery to notification-orchestrator which fans out to email/sms/push channels.",
      "subjects": ["notify.>"],
      "retention": "workqueue",
      "storage": "file",
      "max_age": 86400,
      "max_msgs": 5000000,
      "max_bytes": 1073741824,
      "max_msg_size": 131072,
      "num_replicas": 1,
      "discard": "old",
      "duplicate_window": 300,
      "allow_rollup_hdrs": false,
      "deny_delete": false,
      "deny_purge": false,
      "consumers": [
        {
          "name": "notification-orchestrator-consumer",
          "filter_subject": "notify.>",
          "deliver_policy": "all",
          "ack_policy": "explicit",
          "replay_policy": "instant",
          "max_ack_pending": 1000,
          "ack_wait": 30000000000,
          "max_deliver": 5,
          "description": "notification-orchestrator (Node.js) — processes and routes to channels"
        },
        {
          "name": "in-app-notification-consumer",
          "filter_subject": "notify.inapp.>",
          "deliver_policy": "all",
          "ack_policy": "explicit",
          "replay_policy": "instant",
          "max_ack_pending": 500,
          "ack_wait": 10000000000,
          "max_deliver": 3,
          "description": "in-app-notification-service (Go) — delivers to WebSocket clients"
        }
      ]
    },
    {
      "name": "CHAT_MESSAGES",
      "description": "In-memory stream for live-chat messages in live-chat-service. High throughput, bounded message count, no persistence beyond memory.",
      "subjects": ["chat.>"],
      "retention": "limits",
      "storage": "memory",
      "max_msgs": 100000,
      "max_bytes": 104857600,
      "max_msg_size": 32768,
      "max_age": 0,
      "num_replicas": 1,
      "discard": "old",
      "duplicate_window": 60,
      "allow_rollup_hdrs": false,
      "deny_delete": false,
      "deny_purge": false,
      "consumers": [
        {
          "name": "live-chat-service-consumer",
          "filter_subject": "chat.>",
          "deliver_policy": "last_per_subject",
          "ack_policy": "none",
          "replay_policy": "instant",
          "description": "live-chat-service (Go) — pushes messages to WebSocket clients"
        }
      ]
    },
    {
      "name": "PRESENCE",
      "description": "Ultra-low-latency memory stream for user presence signals (online/offline/typing). Sub-second TTL per message.",
      "subjects": ["presence.>"],
      "retention": "limits",
      "storage": "memory",
      "max_msgs": 50000,
      "max_bytes": 10485760,
      "max_msg_size": 1024,
      "max_age": 10,
      "num_replicas": 1,
      "discard": "old",
      "duplicate_window": 5,
      "consumers": [
        {
          "name": "presence-consumer",
          "filter_subject": "presence.>",
          "deliver_policy": "new",
          "ack_policy": "none",
          "replay_policy": "instant",
          "description": "live-chat-service (Go) — tracks online users"
        }
      ]
    },
    {
      "name": "INVENTORY_UPDATES",
      "description": "File-backed stream for real-time inventory level change events. Consumed by inventory-service and recommendation-service for availability-aware recommendations.",
      "subjects": ["inventory.>"],
      "retention": "limits",
      "storage": "file",
      "max_age": 43200,
      "max_msgs": 500000,
      "max_bytes": 536870912,
      "max_msg_size": 16384,
      "num_replicas": 1,
      "discard": "old",
      "duplicate_window": 60,
      "consumers": [
        {
          "name": "inventory-service-consumer",
          "filter_subject": "inventory.level.>",
          "deliver_policy": "new",
          "ack_policy": "explicit",
          "replay_policy": "instant",
          "max_ack_pending": 2000,
          "description": "inventory-service (Go) — applies level changes"
        },
        {
          "name": "recommendation-consumer",
          "filter_subject": "inventory.out_of_stock.>",
          "deliver_policy": "new",
          "ack_policy": "explicit",
          "replay_policy": "instant",
          "description": "recommendation-service (Python) — filters OOS products from recs"
        }
      ]
    }
  ]
}

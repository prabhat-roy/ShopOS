# Prefect environment variables
# Copy to .env and fill in real values before deploying

PREFECT_API_URL=http://prefect.shopos.internal/api
PREFECT_API_KEY=changeme-replace-with-real-api-key
PREFECT_SERVER_API_HOST=0.0.0.0
PREFECT_SERVER_API_PORT=4200
PREFECT_UI_ENABLED=true
PREFECT_SERVER_DATABASE_CONNECTION_URL=postgresql+asyncpg://prefect:changeme@postgres:5432/prefect
PREFECT_LOGGING_LEVEL=INFO
PREFECT_HOME=/root/.prefect
